{
  "expo": {
    "name": "ai-interview-mobile",
    "slug": "ai-interview-mobile",
    "version": "1.0.0",
    "orientation": "portrait",
    "userInterfaceStyle": "dark",
    "backgroundColor": "#0A0E17",
    "platforms": [
      "ios",
      "android"
    ],
    "plugins": [
      "@react-native-voice/voice",
      "expo-audio"
    ],
    "android": {
      "permissions": [
        "android.permission.RECORD_AUDIO"
      ],
      "package": "com.anonymous.aiinterviewmobile"
    }
  }
}